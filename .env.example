ADOPT_ENV=dev
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_PATH=/data/adoptmesh.sqlite3
PUBLIC_BASE_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_ROOT_TOPIC=adoptmesh
MQTT_USERNAME=
MQTT_PASSWORD=

MESHTASTIC_SERIAL_PORT=/dev/ttyUSB0
MESHTASTIC_CHANNEL_INDEX=1
RADIO_DRY_RUN=true
RADIO_MAX_TEXT_LEN=120

ADOPT_DEFAULT_ZONE=lyon-nord
ADOPT_BEACON_TTL_SECONDS=900
ADOPT_PROFILE_TTL_SECONDS=86400
ADOPT_RATE_LIMIT_SECONDS=60

ADMIN_TOKEN=change-me-local-only
