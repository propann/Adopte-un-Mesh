# Adopte un Mesh - configuration locale

APP_ENV=development
APP_PUBLIC_BASE_URL=http://adopteunmesh.local
API_URL=http://api:8000
DATABASE_PATH=/data/adoptmesh.sqlite3
HOST_DATABASE_PATH=/srv/adopte-un-mesh/data/adoptmesh.sqlite3
ADOPT_DEFAULT_ZONE=lyon-nord
ADOPT_PROFILE_TTL_SECONDS=86400
ADOPT_ACTIVE_WINDOW_SECONDS=1800
ADOPT_CLAIM_TTL_SECONDS=600
CORS_ORIGINS=http://adopteunmesh.local,http://192.168.4.1,http://localhost:8080

# Secrets: generate locally, never commit real values
ADMIN_TOKEN=
PROFILE_TOKEN_PEPPER=

# Radio bridge / gateway Pi 5
RADIO_DRY_RUN=true
MESHTASTIC_SERIAL_PORT=/dev/ttyUSB0
RADIO_MAX_TEXT_LEN=160
MESHTASTIC_ADOPT_CHANNEL_INDEX=1

# Wi-Fi AP / QR
ADOPTE_AP_SSID=Adopte Un Mesh
ADOPTE_AP_PASSWORD=
ADOPTE_AP_ADDR=192.168.4.1
ADOPTE_LOCAL_DOMAIN=adopteunmesh.local

# Radio baseline
MESHTASTIC_REGION=EU_868
MESHTASTIC_MODEM_PRESET=LONG_FAST
MESHTASTIC_HOP_LIMIT=3
MESHTASTIC_SECONDARY_CHANNEL=ADOPT
MESHTASTIC_POSITION_PRECISION=0
MESHTASTIC_PRIMARY_POSITION_PRECISION=13
MESHTASTIC_ADOPT_POSITION_PRECISION=13
ADOPT_POSITION_MODE=city
ADOPT_ALLOW_PRECISE_POSITION=false

# Private ADOPT channel PSK, base64 encoded. Generate locally with:
# ./scripts/create_adopt_channel_key.sh
ADOPT_CHANNEL_PSK=

# MQTT private on the Pi. Do not expose port 1883 to the Internet.
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_INBOUND_TOPIC=adopte/mesh/inbound
MQTT_OUTBOUND_TOPIC=adopte/mesh/outbound/adopt
MQTT_STATUS_TOPIC=adopte/mesh/status
# Read-only by default. Enable only after field tests and ACL setup.
MQTT_ALLOW_OUTBOUND=false
